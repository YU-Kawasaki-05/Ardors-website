# Contact form
# CONTACT_EMAIL_TO — 送信先メールアドレス (例: you@example.com)
CONTACT_EMAIL_TO=
# RESEND_FROM_EMAIL — Resend の送信元メールアドレス
RESEND_FROM_EMAIL=noreply@mail.kaisatsu.com
# RESEND_API_KEY — Resend を使う場合に設定。未設定時は console.log スタブ動作。
RESEND_API_KEY=

# Admin auth (FR-42)
# ADMIN_PASSWORD_HASH — PBKDF2 形式: pbkdf2$sha256$310000$<salt-base64url>$<hash-base64url>
ADMIN_EMAIL=
ADMIN_PASSWORD_HASH=
# ADMIN_SESSION_SECRET — 32文字以上のランダム文字列を推奨
ADMIN_SESSION_SECRET=

# Case CMS store (FR-40 / FR-41)
# 初期実装は file を使用。Vercel Hobby 本番では永続化されないため、外部ストア移行を推奨。
WORKS_STORE_MODE=file
WORKS_FILE_PATH=data/works.json

# GA4 (FR-32)
NEXT_PUBLIC_GA4_ID=

# Google Search Console (FR-33)
# GOOGLE_SITE_VERIFICATION — Search Console のドメイン確認用 meta タグ値
GOOGLE_SITE_VERIFICATION=

# Note RSS (FR-30)
NOTE_RSS_URL=
